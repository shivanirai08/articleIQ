# Copy this file to `.env` and fill in real values.
# Never commit `.env` (it is gitignored).

# Gemini API key — required from Checkpoint 9 onward
GEMINI_API_KEY=

# Application
APP_NAME=ArticleIQ
APP_ENV=development
API_PREFIX=/api/v1

# CORS — frontend origin (Checkpoint 3/5)
CORS_ORIGINS=http://localhost:3000
