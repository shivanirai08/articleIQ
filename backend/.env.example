# Copy this file to `.env` in the same directory (`backend/.env`).
# Never commit `.env` — it is gitignored.

# --- Application ---
APP_NAME=ArticleIQ
APP_ENV=development
API_PREFIX=/api/v1

# --- CORS (Next.js dev server) ---
CORS_ORIGINS=http://localhost:3000

# --- LLM: Grok / Groq (GROK_API_KEY) ---
# Groq keys start with gsk_  → https://console.groq.com/keys
# xAI Grok keys start with xai- → https://console.x.ai/
GROK_API_KEY=
# Optional override (auto-detected if empty):
# GROK_MODEL=llama-3.3-70b-versatile
# LLM_BASE_URL=https://api.groq.com/openai/v1

LLM_TEMPERATURE=0.3
LLM_TOP_P=0.95
LLM_MAX_OUTPUT_TOKENS=1024

# --- spaCy ---
SPACY_MODEL=en_core_web_sm
SPACY_TOKEN_PREVIEW_LIMIT=150
