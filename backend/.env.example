# Copy this file to `.env` in the same directory (`backend/.env`).
# Never commit `.env` — it is gitignored.
#
# Load order (later wins):
#   defaults in code → this file → real environment variables

# --- Application ---
APP_NAME=ArticleIQ
APP_ENV=development
API_PREFIX=/api/v1

# --- CORS (Objective O6 — Next.js dev server) ---
# Comma-separated list of allowed browser origins
CORS_ORIGINS=http://localhost:3000

# --- Google Gemini (Checkpoint 9+) ---
# Get a key from Google AI Studio / Google Cloud — keep server-side only
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
